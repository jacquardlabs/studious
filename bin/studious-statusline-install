#!/usr/bin/env bash
# studious-statusline-install — wires (or unwires) the gate-status segment into
# this project's Claude Code statusline. Installs to .claude/settings.local.json
# only — gitignored, project-scoped, never touches the user's global settings or
# a shared, checked-in .claude/settings.json.
set -uo pipefail

have() { command -v "$1" >/dev/null 2>&1; }

if ! have jq || ! have git; then
  echo "studious-statusline-install: jq and git are required" >&2
  exit 1
fi

root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "studious-statusline-install: not a git repository" >&2
  exit 1
}

settings="$root/.claude/settings.local.json"
prev_file="$root/.studious/statusline-prev-command"

# The exact command wired into settings.local.json. Self-resolving: globs for
# the newest installed studious plugin's bin/ dir at *render* time (not baked
# in here) because ${CLAUDE_PLUGIN_ROOT} does not expand in statusLine.command
# and the plugin cache path is versioned, changing on every `/plugin update`.
# Falls back to replaying the saved previous command if the plugin isn't found
# (disabled/removed), so the statusline never goes blank. Never replays a
# git-tracked prev-command file — see the matching guard in bin/studious-statusline.
# shellcheck disable=SC2016
SNIPPET='r=$(git rev-parse --show-toplevel 2>/dev/null || pwd); p=$(ls -d "$HOME/.claude/plugins/cache"/*/studious/*/bin 2>/dev/null | sort -V | tail -1); f="$r/.studious/statusline-prev-command"; if [ -n "$p" ] && [ -x "$p/studious-statusline" ]; then exec "$p/studious-statusline"; elif [ -s "$f" ] && ! git -C "$r" ls-files --error-unmatch -- "$f" >/dev/null 2>&1; then bash -c "$(cat "$f")"; fi'

ensure_gitignore_line() { # pattern, message
  local gi="$root/.gitignore"
  if [ ! -f "$gi" ] || ! grep -qxF "$1" "$gi" 2>/dev/null; then
    printf '\n# %s\n%s\n' "$2" "$1" >> "$gi"
  fi
}

# Reads only from files the installing user's own machine controls — never a
# shared, checked-in .claude/settings.json, which a repo author could use to
# smuggle an arbitrary command into the local, persisted
# .studious/statusline-prev-command that studious-statusline later executes
# on every render.
current_statusline_command() {
  local f
  for f in "$root/.claude/settings.local.json" "$HOME/.claude/settings.json"; do
    [ -f "$f" ] || continue
    local c; c=$(jq -r '.statusLine.command // empty' "$f" 2>/dev/null)
    if [ -n "$c" ]; then
      printf '%s' "$c"
      return 0
    fi
  done
  return 0
}

# Only used to give an honest install message — never as a capture source
# (see current_statusline_command above for why the checked-in file is
# deliberately excluded from capture).
shared_statusline_command() {
  [ -f "$root/.claude/settings.json" ] || return 0
  jq -r '.statusLine.command // empty' "$root/.claude/settings.json" 2>/dev/null
}

# A .gitignore entry doesn't untrack a file some earlier commit already added
# (or that an attacker deliberately committed). The render-time guard (see
# bin/studious-statusline) already refuses to replay a tracked prev-command
# file, so this is a hygiene note, not a required security control — warn
# rather than mutate the git index ourselves. Unlike ensure_gitignore_line
# (working-tree only), staging an index change here would be a new class of
# side effect this plugin has never had, on a file the user didn't ask about.
warn_if_prev_file_tracked() {
  if git -C "$root" ls-files --error-unmatch -- "$prev_file" >/dev/null 2>&1; then
    echo "studious-statusline-install: note — .studious/statusline-prev-command is tracked in git and will be ignored on render; untrack it with: git rm --cached .studious/statusline-prev-command" >&2
  fi
}

write_settings_statusline() { # command string
  mkdir -p "$root/.claude"
  local existing="{}"
  [ -f "$settings" ] && existing=$(cat "$settings")
  local tmp; tmp=$(mktemp "$root/.claude/.tmp.XXXXXX")
  # RETURN traps aren't function-scoped — they persist and re-fire on the
  # caller's own return too. This function is called from within cmd_install,
  # so reset the trap before returning or it fires again there against an
  # out-of-scope $tmp.
  trap 'rm -f "$tmp"' RETURN
  printf '%s' "$existing" | jq --arg cmd "$1" \
    '.statusLine = {type: "command", command: $cmd}' > "$tmp" && mv "$tmp" "$settings"
  trap - RETURN
}

cmd_install() {
  if [ -f "$settings" ]; then
    local existing_cmd; existing_cmd=$(jq -r '.statusLine.command // empty' "$settings" 2>/dev/null)
    case "$existing_cmd" in
      *studious-statusline*)
        echo "studious-statusline-install: already installed"
        exit 0
        ;;
    esac
  fi

  local prev; prev=$(current_statusline_command)

  mkdir -p "$root/.studious"
  printf '%s' "$prev" > "$prev_file"
  warn_if_prev_file_tracked
  ensure_gitignore_line ".studious/" "Studious local gate ledger (do not commit)"

  write_settings_statusline "$SNIPPET"
  ensure_gitignore_line ".claude/settings.local.json" "Claude Code local settings (do not commit)"

  if [ -n "$prev" ]; then
    echo "studious-statusline-install: wrapped your existing statusLine and added the gate segment"
  elif [ -n "$(shared_statusline_command)" ]; then
    echo "studious-statusline-install: installed the gate segment — found a statusLine in the committed .claude/settings.json, but did not wrap it (a shared, checked-in file could smuggle a command into what runs on every render); it will be shadowed while the segment is installed. Configure your own in .claude/settings.local.json to have it wrapped instead."
  else
    echo "studious-statusline-install: installed the gate segment (no previous statusLine found)"
  fi
}

cmd_remove() {
  local existing_cmd=""
  [ -f "$settings" ] && existing_cmd=$(jq -r '.statusLine.command // empty' "$settings" 2>/dev/null)
  case "$existing_cmd" in
    *studious-statusline*) ;;
    *)
      echo "studious-statusline-install: not installed, nothing to remove"
      exit 0
      ;;
  esac

  local prev=""
  [ -f "$prev_file" ] && prev=$(cat "$prev_file")

  local tmp; tmp=$(mktemp "$root/.claude/.tmp.XXXXXX")
  trap 'rm -f "$tmp"' RETURN
  if [ -n "$prev" ]; then
    jq --arg cmd "$prev" '.statusLine.command = $cmd' "$settings" > "$tmp" && mv "$tmp" "$settings"
  else
    jq 'del(.statusLine)' "$settings" > "$tmp" && mv "$tmp" "$settings"
  fi
  rm -f "$prev_file"

  if [ -n "$prev" ]; then
    echo "studious-statusline-install: removed, restored your previous statusLine"
  else
    echo "studious-statusline-install: removed, no previous statusLine to restore"
  fi
}

case "${1:-}" in
  remove) cmd_remove ;;
  "")     cmd_install ;;
  *)      echo "usage: studious-statusline-install [remove]" >&2; exit 2 ;;
esac
