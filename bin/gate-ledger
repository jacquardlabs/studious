#!/usr/bin/env bash
# gate-ledger — read/write Studious's local, gitignored .studious/ state.
#
# Five stores in the consuming project:
#   .studious/gates/<branch-slug>.json  — per-branch gate verdicts. Written by the
#     gate commands (via `record`); read by the PR-time hook (via `status`) and by
#     /work-on's evidence check (via `gate-get`) — never read as a raw file by callers.
#     A gate's entry optionally carries `blockingLanes` (delta-scoped re-audit, #130):
#     set only via `record --gate audit --blocking-lanes L1,L2` when the audit verdict
#     is FIX AND RE-AUDIT; read back via `gate-get` by commands/gate-audit.md and
#     workflows/epic-driver.js to narrow the *next* re-audit's dispatch width. Absent on
#     every other verdict and on every record written before this field existed —
#     indistinguishable from "malformed," which both readers fail closed on (full audit).
#   .studious/work/<feature-slug>.json  — per-feature flow position for /work-on
#     (written via `work-set` / `work-log`; read via `work-get` / `work-list`).
#   .studious/epics/<epic-slug>.json  — per-epic plan and story DAG for /work-through (written via epic-set / epic-story-set; read via epic-get / epic-list).
#   .studious/epics/<epic-slug>.events.jsonl — append-only status-transition and
#     verdict-recording trail for stories running under that epic (one JSON object
#     per line, appended by the shared `append_event()` helper from `record`,
#     `epic-set`, `epic-story-set`, `work-set`, and `work-log` — see
#     reference/events-format.md). Epic/story attribution is derived from the
#     branch name or the epic-qualified `--slug` convention those verbs already
#     use, never a new flag. Best-effort: a failure appending a line signals on
#     stderr but never fails the calling verb's own exit code — no reader exists
#     yet (a later, dependent story is the first).
#   .studious/evidence/<branch-slug>.jsonl — append-only, harness-captured record
#     of verification commands run while a story is armed (one JSON object per
#     line; written via `evidence-append` by hooks/evidence-capture.sh; read via
#     `evidence-list` — see reference/evidence-format.md).
# All five stores are anchored to the MAIN working tree (see repo_root), so
# agents running in linked worktrees (e.g. /work-through story worktrees)
# share one .studious/ store instead of fragmenting it per worktree.
# Degrades silently when git or jq is unavailable.
set -uo pipefail

branch_name() { git rev-parse --abbrev-ref HEAD 2>/dev/null || echo HEAD; }
branch_slug() { local b; b="${1:-$(branch_name)}"; printf '%s' "${b//\//-}"; } # optional arg: slug for a given branch instead of the current one
head_sha()    { git rev-parse --short HEAD 2>/dev/null || echo ""; }
now_iso()     { date -u +%Y-%m-%dT%H:%M:%SZ; }

have() { command -v "$1" >/dev/null 2>&1; }

repo_root() {
  # Anchor state to the MAIN working tree so agents running in linked
  # worktrees (e.g. /work-through story worktrees) share one .studious/ store.
  local common
  common=$(git rev-parse --git-common-dir 2>/dev/null) || return 1
  common=$(cd "$common" 2>/dev/null && pwd) || return 1  # may be relative ".git"
  case "$common" in
    */.git) printf '%s' "${common%/.git}" ;;
    *) git rev-parse --show-toplevel 2>/dev/null ;;  # bare/odd layouts: old behavior
  esac
}

ledger_dir() {
  # Anchor to the main working tree root so the ledger location doesn't
  # depend on the caller's CWD or which linked worktree it's running in.
  # Degrade to a CWD-relative path if we're not in a git repo at all.
  local root
  if root=$(repo_root); then
    printf '%s/.studious/gates' "$root"
  else
    printf '.studious/gates'
  fi
}

work_dir() {
  # Same root-anchoring as ledger_dir, different store.
  local root
  if root=$(repo_root); then
    printf '%s/.studious/work' "$root"
  else
    printf '.studious/work'
  fi
}

epic_dir() {
  # Same root-anchoring as ledger_dir, different store.
  local root
  if root=$(repo_root); then
    printf '%s/.studious/epics' "$root"
  else
    printf '.studious/epics'
  fi
}

evidence_dir() {
  # Same root-anchoring as ledger_dir, different store. A story worker running
  # in a linked worktree (its own cwd) still lands its records in the MAIN
  # tree's .studious/evidence/, exactly like the other three stores.
  local root
  if root=$(repo_root); then
    printf '%s/.studious/evidence' "$root"
  else
    printf '.studious/evidence'
  fi
}

slugify() {
  # Feature title/slug → filesystem- and JSON-safe key: lowercase, runs of
  # anything outside [a-z0-9] collapse to '-', edges trimmed.
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-*//; s/-*$//'
}

epic_context_from_branch() { # branch name -> prints "epicSlug<TAB>storySlug", nothing if not epic-shaped
  # workflows/epic-driver.js's storyBranch() names the convention: epic/<slug>--<story>
  # for a story branch, epic/<slug> for the epic's own integration branch. Both halves
  # were already slugified before the branch was created, so splitting the remainder on
  # the *first* "--" is unambiguous (see reference/events-format.md).
  local b="$1" rest
  case "$b" in
    epic/*) rest="${b#epic/}" ;;
    *) return 0 ;;  # no epic/ prefix at all: not an epic-dispatched branch, silent no-op
  esac
  case "$rest" in
    *--*) printf '%s\t%s' "${rest%%--*}" "${rest#*--}" ;;
    *)    printf '%s\t' "$rest" ;;  # the epic's own integration branch: epic-level event
  esac
}

epic_context_from_slug() { # raw (pre-slugify) --slug value -> prints "epicSlug<TAB>storySlug", nothing if not epic-qualified
  # Must run on the RAW argument, before the caller's own slug=$(slugify "$slug")
  # reassignment: slugify() collapses "--" to a single "-", which would make this
  # split a silent, permanent no-op if run after (see reference/events-format.md).
  case "$1" in
    *--*) printf '%s\t%s' "${1%%--*}" "${1#*--}" ;;
    *)    return 0 ;;  # never-epic-qualified /work-on feature slug: silent no-op
  esac
}

ensure_gitignore() {
  # Self-heal: keep .studious/ out of the user's git status, even for projects
  # initialized before the ledger existed. Anchored to the main working tree
  # (see repo_root) so a linked worktree self-heals the main .gitignore, not
  # its own.
  local root gi
  root=$(repo_root) || return 0
  gi="$root/.gitignore"
  if [ ! -f "$gi" ] || ! grep -qxF '.studious/' "$gi" 2>/dev/null; then
    printf '\n# Studious local gate ledger (do not commit)\n.studious/\n' >> "$gi"
  fi
}

json_update() { # file, jq filter, then any --arg name value ... pairs for jq
  # Shared writer for every mutating verb: run jq against $file into a
  # same-directory temp file, then rename the temp file over $file on
  # success. Same all-or-nothing outcome as a hand-written block — $file is
  # either untouched or fully replaced with valid jq output — and the same
  # failure behavior: a failing filter leaves $file untouched and the real
  # (non-zero) exit code propagates to the caller.
  #
  # Deliberately no RETURN trap here: a trap armed inside this function
  # doesn't stay scoped to it — bash re-fires it when the *calling* verb
  # itself returns, and by then this function's own $tmp has gone out of
  # scope. Under this script's `set -u`, that's an "unbound variable" abort
  # that would clobber the verb's real (already-succeeded) exit status.
  # Cleanup below is an explicit branch instead, so nothing fires after this
  # function has already returned.
  local file="$1" filter="$2"
  shift 2
  local dir tmp rc
  dir=$(dirname -- "$file")
  tmp=$(mktemp "$dir/.tmp.XXXXXX")
  # Capture $? from the compound command as its own statement, not as the
  # condition of an `if`: POSIX defines the exit status of an `if` with no
  # executed branch (condition false, no `else`) as zero, which would
  # silently discard a real jq/mv failure here and report success.
  jq "$@" "$filter" "$file" > "$tmp" && mv "$tmp" "$file"
  rc=$?
  if [ "$rc" -eq 0 ]; then
    return 0
  fi
  rm -f "$tmp"
  return "$rc"
}

append_event() { # epic, story, kind, jq-object filter for the kind's own fields, then --arg/--argjson pairs for it
  # The append-only counterpart to json_update()'s role: one jq -nc object per
  # call, >> the epic's shared .events.jsonl — same precedent as
  # cmd_evidence_append, no read-modify-write. Best-effort and silent on the
  # happy path: called only after the caller's own primary snapshot write has
  # already succeeded, and a failure here signals on stderr but always returns
  # 0 — this is a secondary, additive log, never a precondition for the
  # primary write it follows (see reference/events-format.md).
  local epic="$1" story="$2" kind="$3" fields="$4"
  shift 4
  if ! have jq || ! have git; then return 0; fi
  local dir; dir=$(epic_dir)
  mkdir -p "$dir" 2>/dev/null
  local file="$dir/$epic.events.jsonl"
  # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
  if ! jq -nc "$@" \
      --arg at "$(now_iso)" --arg epic "$epic" --arg story "$story" --arg kind "$kind" \
      '{at: $at, epic: $epic, story: $story, kind: $kind} + ('"$fields"')' >> "$file" 2>/dev/null
  then
    echo "gate-ledger: events-append failed for epic '$epic' (kind $kind) — primary write unaffected" >&2
  fi
  return 0
}

cmd_record() {
  local gate="" verdict="" blocking_lanes=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --gate)            gate="$2"; shift 2 ;;
      --verdict)         verdict="$2"; shift 2 ;;
      --blocking-lanes)  blocking_lanes="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$gate" ] || [ -z "$verdict" ]; then
    echo "gate-ledger: --gate and --verdict required" >&2
    return 2
  fi
  if ! have jq || ! have git; then
    echo "gate-ledger: record skipped (jq and git required)" >&2
    return 0
  fi

  ensure_gitignore
  local dir; dir=$(ledger_dir)
  mkdir -p "$dir"
  local file; file="$dir/$(branch_slug).json"
  [ -f "$file" ] || printf '{"schemaVersion":1,"branch":"","gates":{}}' > "$file"

  local branch sha rc
  branch="$(branch_name)"
  sha="$(head_sha)"
  # blockingLanes (delta-scoped re-audit, #130): a comma-separated
  # --blocking-lanes list is trimmed/deduped into a JSON array and added to
  # this gate's entry ONLY when given non-empty — every `record` call fully
  # replaces the gate's entry (see .gates[$g] = {...} below), so a verdict
  # recorded WITHOUT --blocking-lanes (a PASS, or a caller that never
  # computed one) correctly leaves the field absent rather than carrying a
  # stale list forward. Absence is exactly the "malformed/unavailable" signal
  # commands/gate-audit.md's and workflows/epic-driver.js's re-audit-scope
  # readers already fail closed on.
  # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
  json_update "$file" \
    'def csv_trim: split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(. != ""));
     .schemaVersion = (.schemaVersion // 1)
     | .branch = $b
     | .gates[$g] = ({verdict: $v, sha: $s, ranAt: $t}
         + (if $bl != "" then {blockingLanes: ($bl | csv_trim)} else {} end))' \
    --arg b "$branch" --arg g "$gate" --arg v "$verdict" \
    --arg s "$sha" --arg t "$(now_iso)" --arg bl "$blocking_lanes"
  rc=$?

  if [ "$rc" -eq 0 ]; then
    local ctx epicSlug storySlug
    ctx=$(epic_context_from_branch "$branch")
    if [ -n "$ctx" ]; then
      IFS=$'\t' read -r epicSlug storySlug <<< "$ctx"
      # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
      append_event "$epicSlug" "$storySlug" "gate-verdict" '{gate: $gate, verdict: $verdict, sha: $sha}' \
        --arg gate "$gate" --arg verdict "$verdict" --arg sha "$sha"
    fi
  fi
  return "$rc"
}

cmd_status() {
  if ! have jq || ! have git; then return 0; fi
  local dir; dir=$(ledger_dir)
  local file; file="$dir/$(branch_slug).json"
  [ -f "$file" ] || return 0

  local head cur_branch stored_branch branch_mismatch
  head=$(head_sha)
  cur_branch=$(branch_name)
  stored_branch=$(jq -r '.branch // empty' "$file")
  branch_mismatch=0
  # branch_slug() collapses '/' to '-', so e.g. feat/foo and feat-foo share a
  # ledger file. If the branch recorded in the file isn't the branch we're
  # actually on, the file was written by the other branch — don't trust its
  # verdicts, report as if nothing was ever recorded for this branch.
  [ "$stored_branch" = "$cur_branch" ] || branch_mismatch=1

  # Gate→pass-token→mode table: "gate:PASS_TOKEN:MODE" entries, audit-then-
  # acceptance-then-pre-mortem order preserved.
  #   required — near-universal; absence itself is worth flagging ("never ran"),
  #     and a clean verdict at HEAD joins the "proceed" summary.
  #   advisory — most branches never record one. The epic finale is the only
  #     intended writer of `pre-mortem`, on an epic's integration branch, but
  #     that write side is not yet wired into workflows/epic-driver.js — this
  #     read side is dormant on every branch until a follow-up adds it (see
  #     the premortem-hook-awareness design doc's Out of scope section,
  #     docs/superpowers/specs/2026-07-09-premortem-hook-awareness-design.md,
  #     for the full rationale). The CLEAR/REALIZED roll-up vocabulary read
  #     here has its canonical home in reference/gate-vocabulary.md, distinct
  #     from the per-item REALIZED / NOT REALIZED / CAN'T VERIFY vocabulary
  #     agents/premortem-auditor.md emits. Absence means "not applicable
  #     here," not "should have run and didn't," so an advisory gate stays
  #     silent both when absent AND when clean at HEAD; it only speaks up to
  #     flag a stale or non-passing verdict.
  local gates=("audit:PASS:required" "acceptance:SHIP:required" "pre-mortem:CLEAR:advisory")
  local msgs=()
  local pass_parts=()
  local gate pass mode v s entry rest
  for entry in "${gates[@]}"; do
    gate="${entry%%:*}"
    rest="${entry#*:}"
    pass="${rest%%:*}"
    mode="${rest##*:}"
    if [ "$branch_mismatch" -eq 1 ]; then
      v=""
      s=""
    else
      # Use --arg + bracket index: dot-syntax (.gates.$gate) parses '-' as
      # subtraction and compile-errors on hyphenated gate names (e.g. the
      # planned should-we-build / design-review gates).
      v=$(jq -r --arg g "$gate" '.gates[$g].verdict // empty' "$file")
      s=$(jq -r --arg g "$gate" '.gates[$g].sha // empty' "$file")
    fi
    if [ -z "$v" ]; then
      [ "$mode" = "required" ] && msgs+=("$gate never ran on this branch")
      continue
    fi
    if [ "$s" != "$head" ]; then
      n=$(git rev-list --count "$s..$head" 2>/dev/null || git rev-list --count "$s..HEAD" 2>/dev/null)
      if [ -n "$n" ] && [ "$n" -gt 0 ] 2>/dev/null; then
        if [ "$n" -eq 1 ]; then unit=commit; else unit=commits; fi
        msgs+=("$gate ran $n $unit ago — re-run before merging")
      else
        msgs+=("$gate ran at $s but HEAD is $head — re-run before merging")
      fi
      continue
    fi
    if [ "$v" != "$pass" ]; then
      msgs+=("$gate returned $v")
      continue
    fi
    # Clean at HEAD: required gates join the proceed summary; an advisory
    # gate's clean state (CLEAR) is silent, same as its absence.
    [ "$mode" = "required" ] && pass_parts+=("$gate ($pass)")
  done

  if [ "${#msgs[@]}" -eq 0 ]; then
    local pass_str=""
    if [ "${#pass_parts[@]}" -gt 0 ]; then
      pass_str="${pass_parts[0]}"
      local i
      for (( i=1; i<${#pass_parts[@]}; i++ )); do
        pass_str="$pass_str and ${pass_parts[$i]}"
      done
    fi
    printf '%s ran on this branch at HEAD — proceed.' "$pass_str"
  else
    local joined; joined=$(printf '%s; ' "${msgs[@]}"); joined=${joined%; }
    printf 'Studious gate check — %s. Proceed anyway?' "$joined"
  fi
}

cmd_gate_get() {
  local branch=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --branch) branch="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  local slug; slug=$(branch_slug "$branch")
  local file; file="$(ledger_dir)/$slug.json"
  [ -f "$file" ] || return 0
  cat "$file"
}

work_file_init() { # slug → ensures the work file exists, echoes its path
  local slug="$1"
  local dir; dir=$(work_dir)
  mkdir -p "$dir"
  local file; file="$dir/$slug.json"
  [ -f "$file" ] || printf '{"schemaVersion":1,"slug":"%s","history":[]}' "$slug" > "$file"
  printf '%s' "$file"
}

cmd_work_set() {
  local slug="" title="" src="" branch="" doc="" phase=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug)       slug="$2"; shift 2 ;;
      --title)      title="$2"; shift 2 ;;
      --source)     src="$2"; shift 2 ;;
      --branch)     branch="$2"; shift 2 ;;
      --design-doc) doc="$2"; shift 2 ;;
      --phase)      phase="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$slug" ]; then
    echo "gate-ledger: --slug required" >&2
    return 2
  fi
  if ! have jq || ! have git; then
    echo "gate-ledger: work-set skipped (jq and git required)" >&2
    return 0
  fi

  local raw_slug="$slug"
  slug=$(slugify "$slug")
  if [ -z "$slug" ]; then
    echo "gate-ledger: --slug reduced to nothing after slugify" >&2
    return 2
  fi

  ensure_gitignore
  local file; file=$(work_file_init "$slug")
  local rc
  # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
  json_update "$file" \
    '.schemaVersion = (.schemaVersion // 1)
     | .createdAt = (.createdAt // $t)
     | .updatedAt = $t
     | (if $title  != "" then .title     = $title  else . end)
     | (if $src    != "" then .source    = $src    else . end)
     | (if $branch != "" then .branch    = $branch else . end)
     | (if $doc    != "" then .designDoc = $doc    else . end)
     | (if $phase  != "" then .phase     = $phase  else . end)' \
    --arg title "$title" --arg src "$src" --arg branch "$branch" \
    --arg doc "$doc" --arg phase "$phase" --arg t "$(now_iso)"
  rc=$?

  if [ "$rc" -eq 0 ] && [ -n "$phase" ]; then
    local ctx epicSlug storySlug
    ctx=$(epic_context_from_slug "$raw_slug")
    if [ -n "$ctx" ]; then
      IFS=$'\t' read -r epicSlug storySlug <<< "$ctx"
      # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
      append_event "$epicSlug" "$storySlug" "phase" '{phase: $phase}' --arg phase "$phase"
    fi
  fi
  return "$rc"
}

cmd_work_log() {
  local slug="" step="" outcome="" phase=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug)    slug="$2"; shift 2 ;;
      --step)    step="$2"; shift 2 ;;
      --outcome) outcome="$2"; shift 2 ;;
      --phase)   phase="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$slug" ] || [ -z "$step" ] || [ -z "$outcome" ]; then
    echo "gate-ledger: --slug, --step, and --outcome required" >&2
    return 2
  fi
  if ! have jq || ! have git; then
    echo "gate-ledger: work-log skipped (jq and git required)" >&2
    return 0
  fi

  local raw_slug="$slug"
  slug=$(slugify "$slug")
  if [ -z "$slug" ]; then
    echo "gate-ledger: --slug reduced to nothing after slugify" >&2
    return 2
  fi

  ensure_gitignore
  local file; file=$(work_file_init "$slug")
  local sha rc
  sha="$(head_sha)"
  # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
  json_update "$file" \
    '.history = ((.history // []) + [{step: $step, outcome: $outcome, sha: $s, at: $t}])
     | .updatedAt = $t
     | (if $phase != "" then .phase = $phase else . end)' \
    --arg step "$step" --arg outcome "$outcome" --arg phase "$phase" \
    --arg s "$sha" --arg t "$(now_iso)"
  rc=$?

  if [ "$rc" -eq 0 ]; then
    local ctx epicSlug storySlug
    ctx=$(epic_context_from_slug "$raw_slug")
    if [ -n "$ctx" ]; then
      IFS=$'\t' read -r epicSlug storySlug <<< "$ctx"
      # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
      append_event "$epicSlug" "$storySlug" "step" \
        '{step: $step, outcome: $outcome} + (if $phase != "" then {phase: $phase} else {} end) + {sha: $sha}' \
        --arg step "$step" --arg outcome "$outcome" --arg phase "$phase" --arg sha "$sha"
    fi
  fi
  return "$rc"
}

cmd_work_get() {
  local slug=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug) slug="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$slug" ]; then
    echo "gate-ledger: --slug required" >&2
    return 2
  fi
  slug=$(slugify "$slug")
  local file; file="$(work_dir)/$slug.json"
  [ -f "$file" ] || return 0
  cat "$file"
}

epic_file_init() { # slug → ensures the epic file exists, echoes its path
  local slug="$1"
  local dir; dir=$(epic_dir)
  mkdir -p "$dir"
  local file; file="$dir/$slug.json"
  [ -f "$file" ] || printf '{"schemaVersion":1,"slug":"%s","status":"planning","stories":{}}' "$slug" > "$file"
  printf '%s' "$file"
}

cmd_epic_set() {
  local slug="" title="" src="" goal="" branch="" premortem="" concurrency="" status=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug)        slug="$2"; shift 2 ;;
      --title)       title="$2"; shift 2 ;;
      --source)      src="$2"; shift 2 ;;
      --goal)        goal="$2"; shift 2 ;;
      --branch)      branch="$2"; shift 2 ;;
      --premortem)   premortem="$2"; shift 2 ;;
      --concurrency) concurrency="$2"; shift 2 ;;
      --status)      status="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$slug" ]; then
    echo "gate-ledger: --slug required" >&2
    return 2
  fi
  case "$concurrency" in
    '') ;; # not provided: fine, left unset in the jq update
    *[!0-9]*|0) echo "gate-ledger: --concurrency must be a positive integer" >&2; return 2 ;;
  esac
  if ! have jq || ! have git; then
    echo "gate-ledger: epic-set skipped (jq and git required)" >&2
    return 0
  fi

  slug=$(slugify "$slug")
  if [ -z "$slug" ]; then
    echo "gate-ledger: --slug reduced to nothing after slugify" >&2
    return 2
  fi

  ensure_gitignore
  local file; file=$(epic_file_init "$slug")
  local rc
  # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
  json_update "$file" \
    '.schemaVersion = (.schemaVersion // 1)
     | .createdAt = (.createdAt // $t)
     | .updatedAt = $t
     | (if $title  != "" then .title       = $title  else . end)
     | (if $src    != "" then .source      = $src    else . end)
     | (if $goal   != "" then .goal        = $goal   else . end)
     | (if $branch != "" then .branch      = $branch else . end)
     | (if $pm     != "" then .premortem   = $pm     else . end)
     | (if $conc   != "" then .concurrency = ($conc | tonumber) else . end)
     | (if $status != "" then .status      = $status else . end)' \
    --arg title "$title" --arg src "$src" --arg goal "$goal" --arg branch "$branch" \
    --arg pm "$premortem" --arg conc "$concurrency" --arg status "$status" --arg t "$(now_iso)"
  rc=$?

  if [ "$rc" -eq 0 ] && [ -n "$status" ]; then
    # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
    append_event "$slug" "" "epic-status" '{status: $status}' --arg status "$status"
  fi
  return "$rc"
}

cmd_epic_get() {
  local slug=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug) slug="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$slug" ]; then
    echo "gate-ledger: --slug required" >&2
    return 2
  fi
  slug=$(slugify "$slug")
  local file; file="$(epic_dir)/$slug.json"
  [ -f "$file" ] || return 0
  cat "$file"
}

cmd_epic_story_set() {
  local epic="" slug="" title="" src="" criteria="" deps="" gates_csv="" status="" reason="" worktree="" bump="" reset=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --epic)        epic="$2"; shift 2 ;;
      --slug)        slug="$2"; shift 2 ;;
      --title)       title="$2"; shift 2 ;;
      --source)      src="$2"; shift 2 ;;
      --criteria)    criteria="$2"; shift 2 ;;
      --deps)        deps="$2"; shift 2 ;;
      --gates)       gates_csv="$2"; shift 2 ;;
      --status)      status="$2"; shift 2 ;;
      --reason)      reason="$2"; shift 2 ;;
      --worktree)    worktree="$2"; shift 2 ;;
      --bump-retry)  bump="$2"; shift 2 ;;
      --reset-retry) reset="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$epic" ] || [ -z "$slug" ]; then
    echo "gate-ledger: --epic and --slug required" >&2
    return 2
  fi
  if ! have jq || ! have git; then
    echo "gate-ledger: epic-story-set skipped (jq and git required)" >&2
    return 0
  fi

  epic=$(slugify "$epic")
  slug=$(slugify "$slug")
  if [ -z "$epic" ] || [ -z "$slug" ]; then
    echo "gate-ledger: --epic or --slug reduced to nothing after slugify" >&2
    return 2
  fi

  local file; file="$(epic_dir)/$epic.json"
  if [ ! -f "$file" ]; then
    echo "gate-ledger: no epic file for '$epic' (run epic-set first)" >&2
    return 2
  fi

  local rc
  # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
  json_update "$file" \
    'def csv_trim: split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(. != ""));
     .updatedAt = $t
     | .stories[$s] = ((.stories[$s] // {status: "pending", deps: [], retries: {}})
       | (if $title    != "" then .title    = $title    else . end)
       | (if $src      != "" then .source   = $src      else . end)
       | (if $criteria != "" then .criteria = $criteria else . end)
       | (if $deps     != "" then .deps     = ($deps  | csv_trim) else . end)
       | (if $gates    != "" then .gates    = ($gates | csv_trim) else . end)
       | (if $status   != "" then .status   = $status   else . end)
       | (if $reason   != "" then .reason   = $reason   else . end)
       | (if $wt       != "" then .worktree = $wt       else . end)
       | (if $bump     != "" then .retries[$bump]  = ((.retries[$bump]  // 0) + 1) else . end)
       | (if $reset    != "" then .retries[$reset] = 0 else . end))' \
    --arg s "$slug" --arg title "$title" --arg src "$src" --arg criteria "$criteria" \
    --arg deps "$deps" --arg gates "$gates_csv" --arg status "$status" --arg reason "$reason" \
    --arg wt "$worktree" --arg bump "$bump" --arg reset "$reset" --arg t "$(now_iso)"
  rc=$?

  if [ "$rc" -eq 0 ] && { [ -n "$status" ] || [ -n "$reason" ] || [ -n "$bump" ] || [ -n "$reset" ]; }; then
    # Both retry counters are read back post-write (the events line always
    # reflects the file's new state, not a value computed independently of it).
    local bump_retries="0" reset_retries="0"
    [ -n "$bump" ]  && bump_retries=$(jq -r --arg s "$slug" --arg g "$bump" '.stories[$s].retries[$g] // 0' "$file")
    [ -n "$reset" ] && reset_retries=$(jq -r --arg s "$slug" --arg g "$reset" '.stories[$s].retries[$g] // 0' "$file")
    # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
    append_event "$epic" "$slug" "story" \
      '(if $status != "" then {status: $status} else {} end)
       + (if $reason != "" then {reason: $reason} else {} end)
       + (if $bump   != "" then {bumpRetryGate: $bump, retries: ($bumpRetries | tonumber)} else {} end)
       + (if $reset  != "" then {resetRetryGate: $reset, retries: ($resetRetries | tonumber)} else {} end)' \
      --arg status "$status" --arg reason "$reason" --arg bump "$bump" --arg reset "$reset" \
      --arg bumpRetries "$bump_retries" --arg resetRetries "$reset_retries"
  fi
  return "$rc"
}

cmd_epic_list() {
  if ! have jq; then return 0; fi
  local dir; dir=$(epic_dir)
  local f
  for f in "$dir"/*.json; do
    [ -e "$f" ] || continue
    jq -r '[(.slug // "?"), (.status // "?"),
            (([.stories[] | select(.status == "landed")] | length | tostring) + "/" + (.stories | length | tostring)),
            (.branch // "-"), (.title // "-")] | @tsv' "$f" 2>/dev/null
  done
}

cmd_work_list() {
  if ! have jq; then return 0; fi
  local dir; dir=$(work_dir)
  local f
  for f in "$dir"/*.json; do
    [ -e "$f" ] || continue
    jq -r '[(.slug // "?"), (.phase // "?"), (.branch // "-"), (.title // "-")] | @tsv' "$f" 2>/dev/null
  done
}

cmd_gc() {
  if ! have jq || ! have git; then return 0; fi
  local dir; dir=$(ledger_dir)
  local f branch
  for f in "$dir"/*.json; do
    [ -e "$f" ] || continue
    branch=$(jq -r '.branch // empty' "$f" 2>/dev/null)
    [ -n "$branch" ] || continue
    if ! git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null 2>&1; then
      rm -f "$f"
      printf 'removed stale ledger: %s (branch %s no longer exists)\n' "$(basename "$f")" "$branch"
    fi
  done

  # Work files: prune only those tied to a branch that's gone. A work file with
  # no branch yet (decide/design phases happen before one exists) is kept.
  local wdir; wdir=$(work_dir)
  for f in "$wdir"/*.json; do
    [ -e "$f" ] || continue
    branch=$(jq -r '.branch // empty' "$f" 2>/dev/null)
    [ -n "$branch" ] || continue
    if ! git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null 2>&1; then
      rm -f "$f"
      printf 'removed stale work file: %s (branch %s no longer exists)\n' "$(basename "$f")" "$branch"
    fi
  done
}

cmd_evidence_append() { # append-only: one jq -nc object per call, >> the branch's .jsonl
  local command="" exit_code="" output_digest="" origin="" agent_type=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --command)       command="$2"; shift 2 ;;
      --exit-code)     exit_code="$2"; shift 2 ;;
      --output-digest) output_digest="$2"; shift 2 ;;
      --origin)        origin="$2"; shift 2 ;;
      --agent-type)    agent_type="$2"; shift 2 ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  if [ -z "$command" ] || [ -z "$exit_code" ] || [ -z "$output_digest" ] || [ -z "$origin" ]; then
    echo "gate-ledger: --command, --exit-code, --output-digest, and --origin required" >&2
    return 2
  fi
  case "$exit_code" in
    ''|*[!0-9]*) echo "gate-ledger: --exit-code must be a non-negative integer" >&2; return 2 ;;
  esac
  case "$origin" in
    interactive|subagent) ;;
    *) echo "gate-ledger: --origin must be 'interactive' or 'subagent'" >&2; return 2 ;;
  esac
  if ! have jq || ! have git; then
    echo "gate-ledger: evidence-append skipped (jq and git required)" >&2
    return 0
  fi

  ensure_gitignore
  local dir; dir=$(evidence_dir)
  mkdir -p "$dir"
  local file; file="$dir/$(branch_slug).jsonl"

  # capturer is hardcoded, never a caller-supplied flag: only this verb may
  # write "hook" as the capturer, so a caller can't spoof a different one.
  # predicateType/predicate.configuration are fixed to the one in-toto
  # test-result shape this story maps every captured command onto (see
  # reference/evidence-format.md) — not exposed as flags in v0.
  # shellcheck disable=SC2016 # jq's own $var syntax, not shell expansion
  jq -nc \
    --arg capturedAt "$(now_iso)" --arg origin "$origin" --arg agentType "$agent_type" \
    --arg command "$command" --argjson exitCode "$exit_code" --arg outputDigest "$output_digest" \
    '{capturedAt: $capturedAt, capturer: "hook", origin: $origin}
     + (if $agentType != "" then {agentType: $agentType} else {} end)
     + {command: $command, exitCode: $exitCode, outputDigest: $outputDigest,
        predicateType: "https://in-toto.io/attestation/test-result/v0.1",
        predicate: {result: (if $exitCode == 0 then "PASSED" else "FAILED" end),
                    configuration: [{name: $command}]}}' >> "$file"
}

cmd_evidence_list() { # optional --branch B: print that branch's evidence .jsonl verbatim; optional --dedupe: collapse to one record per distinct command (most recent wins), nothing if absent
  local branch="" dedupe=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --branch) branch="$2"; shift 2 ;;
      --dedupe) dedupe=1; shift ;;
      *) echo "gate-ledger: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  # Same evidence_dir()/branch_slug() anchoring evidence-append already uses,
  # so a caller (e.g. /handback) never re-derives repo-root or slug logic
  # itself — one place this store's location lives, reused by both the
  # writer and this reader. Mirrors cmd_gate_get's shape: resolve one
  # branch's file, print it verbatim, nothing if it doesn't exist yet.
  local slug; slug=$(branch_slug "$branch")
  local file; file="$(evidence_dir)/$slug.jsonl"
  [ -f "$file" ] || return 0

  if [ -z "$dedupe" ]; then
    # Never requires jq: reading and emitting the raw file needs no JSON parsing.
    cat "$file"
    return 0
  fi

  # --dedupe: keep exactly one record per distinct `command` value — the one
  # appended last — printed in the survivors' original (chronological)
  # relative order. Index-based (to_entries/reduce over a command->last-index
  # map), deliberately not unique_by (which sorts by the grouping key and
  # would reorder output alphabetically by command) or whole-object equality
  # (a latent bug for two records byte-identical in every field, including
  # capturedAt — both would match and both would survive). See
  # docs/superpowers/specs/2026-07-21-evidence-list-dedupe-design.md.
  # Fails closed: no jq, or a malformed line, means no stdout and a non-zero
  # exit — every existing caller already treats an evidence-list error
  # identically to empty output.
  if ! have jq; then
    echo "gate-ledger: evidence-list --dedupe requires jq" >&2
    return 1
  fi
  jq -c -s 'to_entries as $es
    | (reduce $es[] as $e ({}; .[$e.value.command] = $e.key)) as $last_idx
    | $es[] | select(.key == $last_idx[.value.command]) | .value' \
    "$file" \
    || { echo "gate-ledger: evidence-list --dedupe failed to parse $file" >&2; return 1; }
}

case "${1:-}" in
  record)          shift; cmd_record "$@" ;;
  status)          shift; cmd_status "$@" ;;
  gate-get)        shift; cmd_gate_get "$@" ;;
  work-set)        shift; cmd_work_set "$@" ;;
  work-log)        shift; cmd_work_log "$@" ;;
  work-get)        shift; cmd_work_get "$@" ;;
  work-list)       shift; cmd_work_list "$@" ;;
  epic-set)        shift; cmd_epic_set "$@" ;;
  epic-get)        shift; cmd_epic_get "$@" ;;
  epic-story-set)  shift; cmd_epic_story_set "$@" ;;
  epic-list)       shift; cmd_epic_list "$@" ;;
  evidence-append) shift; cmd_evidence_append "$@" ;;
  evidence-list)   shift; cmd_evidence_list "$@" ;;
  gc)              shift; cmd_gc "$@" ;;
  *) echo "usage: gate-ledger {record --gate G --verdict V [--blocking-lanes L1,L2] | status | gate-get [--branch B] | work-set --slug S [--title T] [--source SRC] [--branch B] [--design-doc P] [--phase PH] | work-log --slug S --step ST --outcome O [--phase PH] | work-get --slug S | work-list | epic-set --slug S [--title T] [--source SRC] [--goal G] [--branch B] [--premortem P] [--concurrency N] [--status ST] | epic-story-set --epic E --slug S [--title T] [--source SRC] [--criteria C] [--deps D] [--gates G] [--status ST] [--reason R] [--worktree P] [--bump-retry GATE] [--reset-retry GATE] | epic-get --slug S | epic-list | evidence-append --command C --exit-code N --output-digest D --origin interactive|subagent [--agent-type T] | evidence-list [--branch B] [--dedupe] | gc}" >&2; exit 2 ;;
esac
